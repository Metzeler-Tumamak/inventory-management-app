<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <title>Inventory Management App</title>
    <link
      rel="stylesheet"
      href="/styles.css"
    />
  </head>
  <body>
    
    <dialog class="modal">
      <div class="modal-content">
        <p class="form-header">Form Header</p>
        <form method="POST" 
        action="/products" 
        id="form-add-product"
        class="modal-form hidden" 
        >
        
          <div class="field">
            <label for="name">Name</label>
            <input id="name"  name="name" type="text" required>
          </div>
          <div class="field">
            <label for="category-id">Category</label>
            <select id="category-id" name="category_id">
              <option value="">Others</option>
               <% categories.forEach(category => {%>
                <option value="<%= category.id %>"><%= category.name %></option>
                <% }); %>
            </select>
          </div>
          <div class="field">
            <label for="available">Available</label>
            <input id="available" name="available" type="number" step="1" required>
          </div>
          <div class="field">
            <label for="minimum">Minimum</label>
            <input id="minimum"
            name="minimum"
            type="number"
            step="1"
            required>
          </div>
          <div class="field">
            <label for="maximum">Maximum</label>
            <input type="number"  id="maximum" name="maximum" step="1"
            required
            >
          </div>
          <div class="field">
            <label for="price">Price</label>
            <input id="price" name="price" type="number" step="0.01"
            required>
          </div>
          
        </form>
         <form method="PUT" 
        action="/products" 
        id="form-update-product"
        class="modal-form hidden" 
        >
          <input type="text" name="id" class="hidden">
          <div class="field">
            <label for="name">Name</label>
            <input id="name"  name="name" type="text" required>
          </div>
          <div class="field">
            <label for="category-id">Category</label>
            <select id="category-id" name="category_id">
              <option value="">Others</option>
               <% categories.forEach(category => {%>
                <option value="<%= category.id %>"><%= category.name %></option>
                <% }); %>
            </select>
          </div>
          <div class="field">
            <label for="available">Available</label>
            <input id="available" name="available" type="number" step="1" required>
          </div>
          <div class="field">
            <label for="minimum">Minimum</label>
            <input id="minimum"
            name="minimum"
            type="number"
            step="1"
            required>
          </div>
          <div class="field">
            <label for="maximum">Maximum</label>
            <input type="number"  id="maximum" name="maximum" step="1"
            required
            >
          </div>
          <div class="field">
            <label for="price">Price</label>
            <input id="price" name="price" type="number" step="0.01"
            required>
          </div>
          
        </form>
        <form method="POST" action="/categories" class="modal-form hidden" id="form-add-category">
          <div class="field">
            <input id="name"  name="name" type="text">
          </div>
        </form>
        <form class="modal-form hidden"
        id="form-delete-product"
        method="DELETE" action="/products">
          <p>Are you sure you want to delete this product?</p>
          <input name="id" type="text" class="hidden" >
        </form>
        <form class="modal-form hidden"
        id="form-delete-category"
        method="DELETE" action="/categories">
          <div class="field">
            <select name="id">
              <% categories.forEach(({id, name}) => {%>
                <option value="<%= id %>"><%= name %></option>
                <% }); %>
            </select>
          </div>
        </form>
        <div class="modal-btns"><button class="submit-btn" type="submit">Submit</button>
          <button
          class="cancel-btn" type="button">Cancel</button>
          </div>
      </div>
      
      <div class="loader-wrapper hidden">
        <div class="loader"></div>
      </div>
    </dialog>
    <header>
      <div>
        <h1>Inventory</h1>
        <div class="header-controls">
          <div class="search-bar">
            <label for="search-input"><i class="search-icon" data-lucide="search"></i></label>
            <input
              id="search-input"
              type="text"
              placeholder="Search"
              name="name"
              form="filter-form"
              <%= filters.name.length ? `value=${filters.name}` : "" %>
            />
          </div>
          <div class="add-menu">
            <button
              class="btn add-btn"
              type="button"
            >
              <i data-lucide="plus"></i>
            </button>
            <ul class="add-dropdown hidden">
              <li>
                <button type="button" data-action="add-product"
              >Add product</button>
              </li>
              <li>
                <button type="button"
                data-action="add-category"
                >Add category</button>
              </li>
              <li>
                <button type="button"
                data-action="delete-category"
                >Delete category</button>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </header>
    <main class="content">
      <div class="btns-wrapper">
        <button class="filter-btn" type="button">Filters</button> 
        <button class="share-btn"
        type="button">
          <i data-lucide="share"></i>
        </button>
        <button type="button" class="share-btn">
          <i data-lucide="settings"></i>
        </button>
      </div>
      <form id="filter-form" method="GET" action="/" class="
       filters hidden">
        <fieldset class="categories">
          <div class="category-item">
            <label><input class="hidden" 
              name="category_id" type="radio" value=""
              <%= filters.category_id.length === 0 &&  "checked" %>
              >All</label>
          </div>
          <% categories.forEach(({id, name}) => { %>
            <div class="category-item">
            <label><input class="hidden" name="category_id" type="radio" value="<%= id %>"
                 <%= filters.category_id === id &&  "checked" %>
              ><%= name %></label>
          </div>
          <% }); %>
        </fieldset>
        <div class="sort">
          <label for="sort-select">Sort: </label>
          <select id="sort-select" name="sort">
            <option value="name" 
            <%= filters.sort === "name" && "selected" %>
            >Name</option>
            <option value="available"
            <%= filters.sort === "available" && "selected" %>
            >Available</option>
          </select>

          <fieldset class="sort-order">
           
            <label><i data-lucide="arrow-up-narrow-wide"></i>
           <input class="hidden" type="radio" name="order" value="ASC" 
           <%= filters.order === "ASC" &&  "checked" %>
           >
            </label>
            
            <label><i data-lucide="arrow-down-narrow-wide"></i>
              <input class="hidden" type="radio" name="order" value="DESC"
              <%= filters.order === "DESC" &&  "checked" %>
              >
            </label>
            
          </fieldset>
        </div>
        <div class="filter-form-controls"><button type="submit" disabled>Apply</button>
        <button class="reset-filter-btn" type="button">Reset</button>
        </div>
      </form>
      <div class="products-wrapper">
        <table class="products">
          <thead>
            <tr>
              <th scope="col" class="text-cell sticky-col">Name</th>
              <th scope="col" class="text-cell">Category</th>
              <th scope="col" class="num-cell">Available</th>
              <th scope="col" class="num-cell">Minimum</th>
              <th scope="col" class="num-cell">Maximum</th>
              <th scope="col" class="num-cell">Price</th>
              <th scope="col" class="action-col">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(product => { %>
              <% const {id, name, category, category_id, available, minimum, maximum, price} = product %> 
                <tr data-id="<%= id %>">
                  <th scope="row" class="sticky-col text-cell" data-field="name" data-value="<%= name %>"><%= name %></th>
                  <td class="text-cell" data-field="category_id" data-value="<%= category_id %>"><%= category ?? "Others" %></td>
                  <td class="num-cell" data-field="available" data-value="<%= available %>"><%= available %></td>
                  <td class="num-cell" data-field="minimum" data-value="<%= minimum %>"><%= minimum %></td>
                  <td class="num-cell" data-field="maximum" data-value="<%= maximum %>"><%= maximum %></td>
                  <td class="num-cell" data-field="price" data-value="<%= price %>">$<%= price %></td>
                  <td class="action-cell">
                    <button type="button" data-action="update-product"> 
                      <i data-lucide="pencil"></i>
                    </button>
                    <button type="button" data-action="delete-product">
                      <i data-lucide="trash-2"></i>
                    </button>
                  </td>
                </tr>
              <% }); %>
          </tbody>
        </table>
      </div>
    </main>


    <script src="https://unpkg.com/lucide@1.17.0/dist/umd/lucide.js"></script>

    <script>
      const locals = {
        products: <%- JSON.stringify(locals.products) %>,
        categories: <%- JSON.stringify(locals.categories) %>
      }
    </script>

    <script type="module" src="/index.js"></script>
  </body>
</html>
